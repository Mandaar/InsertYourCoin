# Copie ce fichier en ".env" et renseigne tes cles API Kraken.
# Cree-les sur Kraken : Settings > API.
# Conseil securite : pour commencer, cree une cle SANS permission de retrait
# (uniquement "Query" + "Trade"). Ne partage JAMAIS ces cles.

KRAKEN_API_KEY=ta_cle_publique_ici
KRAKEN_API_SECRET=ta_cle_privee_ici
